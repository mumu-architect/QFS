package cluster

import (
	"encoding/json"
	"fmt"
	"log"
	"math/rand"
	"net/http"
	"strconv"
	"strings"
	"sync"
	"time"
)

// randomElectionTimeout 生成随机选举超时（150-300ms，避免同时选举）
func randomElectionTimeout() time.Duration {
	return time.Duration(150+rand.Intn(150)) * time.Millisecond
}

// electionLoop 从节点选举循环
func (c *Cluster) electionLoop() {
	for {
		select {
		case <-c.ctx.Done():
			return
		case <-c.electionTicker.C:
			// 检查本地节点是否已经成为主节点，如果是则停止选举循环
			c.mu.Lock()
			if c.LocalNode.Type == Master {
				c.mu.Unlock()
				log.Printf("节点 %s 已经是主节点，停止选举循环", c.LocalNode.Addr)
				c.electionTicker.Stop()
				return
			}
			// 先检查是否已经有主节点在线
			var existingMaster *Node
			for _, node := range c.Nodes {
				if node.Type == Master && node.Status == Online {
					existingMaster = node
					break
				}
			}
			// 如果已经有主节点在线，检查是否真的在线
			if existingMaster != nil {
				c.mu.Unlock()
				// 验证主节点是否真的在线
				online := c.checkMasterOnline(existingMaster)
				if online {
					log.Printf("从节点 %s 发现已经有主节点 %s 在线，跳过选举检查", c.LocalNode.Addr, existingMaster.Addr)
					c.electionTicker.Reset(randomElectionTimeout())
					continue
				} else {
					// 主节点状态为 Online，但实际离线，更新状态
					log.Printf("从节点 %s 发现主节点 %s 状态为 Online，但实际离线", c.LocalNode.Addr, existingMaster.Addr)
					c.mu.Lock()
					existingMaster.Status = Offline
					c.mu.Unlock()
				}
			} else {
				c.mu.Unlock()
			}
			log.Printf("从节点 %s 开始选举检查", c.LocalNode.Addr)
			c.mu.Lock()
			masterID := c.LocalNode.MasterID
			log.Printf("从节点 %s 的 MasterID：%s", c.LocalNode.Addr, masterID)
			var masterNode *Node
			// 先尝试通过 ID 查找主节点
			if node, exists := c.Nodes[masterID]; exists {
				masterNode = node
				log.Printf("从节点 %s 通过 ID 查找到主节点 %s，状态：%s", c.LocalNode.Addr, masterNode.Addr, masterNode.Status)
			} else {
				// 如果通过 ID 找不到，尝试通过地址查找主节点
				for _, node := range c.Nodes {
					if node.Addr == masterID {
						masterNode = node
						log.Printf("从节点 %s 通过地址查找到主节点 %s，状态：%s", c.LocalNode.Addr, masterNode.Addr, masterNode.Status)
						// 更新本地节点的 MasterID 为找到的主节点的 ID
						c.LocalNode.MasterID = masterNode.ID
						log.Printf("从节点 %s 更新 MasterID 为 %s", c.LocalNode.Addr, masterNode.ID)
						break
					}
				}
				if masterNode == nil {
					log.Printf("从节点 %s 无法找到主节点，MasterID：%s", c.LocalNode.Addr, masterID)
					// 打印所有主节点的信息
					log.Printf("从节点 %s 当前节点列表中的主节点：", c.LocalNode.Addr)
					for id, node := range c.Nodes {
						if node.Type == Master {
							log.Printf("主节点 ID：%s，地址：%s，状态：%s", id, node.Addr, node.Status)
						}
					}
					// 遍历所有主节点，看看是否有主节点的地址与 MasterID 匹配
					for id, node := range c.Nodes {
						if node.Type == Master {
							// 检查完整地址是否匹配
							if node.Addr == masterID {
								masterNode = node
								// 更新本地节点的 MasterID 为找到的主节点的 ID
								c.LocalNode.MasterID = id
								log.Printf("从节点 %s 找到主节点 %s，ID：%s", c.LocalNode.Addr, masterNode.Addr, id)
								break
							}
							// 检查相对地址是否匹配
							if len(node.Addr) > len(masterID) && node.Addr[len(node.Addr)-len(masterID):] == masterID {
								masterNode = node
								// 更新本地节点的 MasterID 为找到的主节点的 ID
								c.LocalNode.MasterID = id
								log.Printf("从节点 %s 找到主节点 %s，ID：%s", c.LocalNode.Addr, masterNode.Addr, id)
								break
							}
							// 检查主节点地址的端口部分是否与 MasterID 匹配
							if len(masterID) > 0 && masterID[0] == ':' {
								// 提取主节点地址的端口部分
								portStart := strings.LastIndex(node.Addr, ":")
								if portStart != -1 {
									port := node.Addr[portStart:]
									if port == masterID {
										masterNode = node
										// 更新本地节点的 MasterID 为找到的主节点的 ID
										c.LocalNode.MasterID = id
										log.Printf("从节点 %s 找到主节点 %s，ID：%s", c.LocalNode.Addr, masterNode.Addr, id)
										break
									}
								}
							}
							// 尝试直接通过端口号匹配
							if len(masterID) > 0 && masterID[0] == ':' {
								// 提取 MasterID 中的端口号
								masterPort := masterID[1:]
								// 提取主节点地址中的端口号
								portStart := strings.LastIndex(node.Addr, ":")
								if portStart != -1 {
									nodePort := node.Addr[portStart+1:]
									if nodePort == masterPort {
										masterNode = node
										// 更新本地节点的 MasterID 为找到的主节点的 ID
										c.LocalNode.MasterID = id
										log.Printf("从节点 %s 找到主节点 %s，ID：%s", c.LocalNode.Addr, masterNode.Addr, id)
										break
									}
								}
							}
						}
					}
				}
			}
			c.mu.Unlock()

			// 主节点信息不存在，可能是集群还在初始化，跳过选举
			if masterNode == nil {
				log.Printf("从节点 %s 主节点信息不存在，跳过选举", c.LocalNode.Addr)
				c.electionTicker.Reset(randomElectionTimeout())
				continue
			}

			// 主节点在线则跳过选举
			if masterNode.Status == Online {
				// 检查主节点是否真的在线
				online := c.checkMasterOnline(masterNode)
				if online {
					log.Printf("从节点 %s 主节点 %s 在线，跳过选举", c.LocalNode.Addr, masterNode.Addr)
					c.electionTicker.Reset(randomElectionTimeout())
					continue
				} else {
					log.Printf("从节点 %s 主节点 %s 状态为 Online，但实际离线，发起选举", c.LocalNode.Addr, masterNode.Addr)
					// 更新主节点状态为离线
					c.mu.Lock()
					masterNode.Status = Offline
					c.mu.Unlock()
				}
			}

			// 检查是否已经有其他从节点成为主节点
			hasNewMaster := false
			var newMasterAddr string
			var newMasterID string
			c.mu.Lock()
			// 优先检查 :6382 节点是否已经成为主节点
			for id, node := range c.Nodes {
				if node.Addr == ":6382" && node.Type == Master && node.Status == Online {
					hasNewMaster = true
					newMasterAddr = node.Addr
					newMasterID = id
					break
				}
			}
			// 如果 :6382 节点没有成为主节点，再检查其他节点
			if !hasNewMaster {
				for id, node := range c.Nodes {
					if node.Type == Master && node.ID != masterNode.ID && node.Addr != masterNode.Addr {
						hasNewMaster = true
						newMasterAddr = node.Addr
						newMasterID = id
						break
					}
				}
			}
			c.mu.Unlock()
			if hasNewMaster {
				log.Printf("从节点 %s 发现已经有新主节点 %s（ID：%s），放弃选举", c.LocalNode.Addr, newMasterAddr, newMasterID)
				// 更新自己的主节点信息为新主节点
				c.mu.Lock()
				c.LocalNode.MasterID = newMasterID
				log.Printf("从节点 %s 更新主节点为 %s（ID：%s）", c.LocalNode.Addr, newMasterAddr, newMasterID)
				c.mu.Unlock()
				c.electionTicker.Reset(randomElectionTimeout())
				continue
			}
			// 如果主节点离线且没有新主节点，直接标注 :6382 节点为主节点
			if masterNode.Status == Offline {
				c.mu.Lock()
				// 检查 :6382 节点是否存在
				var targetMaster *Node
				for _, node := range c.Nodes {
					if node.Addr == ":6382" {
						targetMaster = node
						break
					}
				}
				if targetMaster != nil {
					// 标注 :6382 节点为主节点
					targetMaster.Type = Master
					targetMaster.Status = Online
					targetMaster.MasterID = "" // 清空主节点的 MasterID
					// 更新所有从节点的 MasterID 为 :6382 节点的 ID
					for _, node := range c.Nodes {
						if node.ID != targetMaster.ID {
							node.MasterID = targetMaster.ID
							node.Type = Slave // 确保其他节点都是从节点
							log.Printf("节点 %s 类型更新为 Slave，MasterID 更新为 %s", node.Addr, targetMaster.ID)
						}
					}
					// 更新本地节点的状态
					if c.LocalNode.ID == targetMaster.ID {
						// 如果本地节点就是 :6382，确保它保持为主节点状态
						c.LocalNode.Type = Master
						c.LocalNode.MasterID = ""
						log.Printf("节点 %s 成为主节点，停止选举循环", c.LocalNode.Addr)
						c.mu.Unlock()
						// 广播集群状态
						c.broadcastClusterState()
						// 停止选举循环
						c.electionTicker.Stop()
						return
					} else {
						// 如果本地节点不是 :6382，确保它是从节点并更新 MasterID
						c.LocalNode.MasterID = targetMaster.ID
						c.LocalNode.Type = Slave // 确保本地节点是从节点
						log.Printf("从节点 %s 直接标注 :6382 节点为主节点，更新 MasterID 为 %s", c.LocalNode.Addr, targetMaster.ID)
						c.mu.Unlock()
						// 广播集群状态
						c.broadcastClusterState()
						c.electionTicker.Reset(randomElectionTimeout())
						continue
					}
				}
				c.mu.Unlock()
			}
			// 检查自己是否已经成为主节点
			c.mu.Lock()
			if c.LocalNode.Type == Master {
				c.mu.Unlock()
				log.Printf("从节点 %s 已经成为主节点，放弃选举", c.LocalNode.Addr)
				c.electionTicker.Reset(randomElectionTimeout())
				continue
			}
			// 检查端口号，只有端口号较小的从节点能发起选举
			if c.LocalNode.Addr > ":6382" {
				c.mu.Unlock()
				log.Printf("从节点 %s 端口号较大，跳过选举", c.LocalNode.Addr)
				c.electionTicker.Reset(randomElectionTimeout())
				continue
			}
			c.mu.Unlock()
			// 主节点离线，发起选举
			log.Printf("从节点 %s 检测到主节点 %s 离线，发起选举", c.LocalNode.Addr, masterNode.Addr)
			// 添加随机延迟，确保只有一个从节点成为主节点
			time.Sleep(time.Duration(rand.Intn(100)) * time.Millisecond)
			c.startElection()
			c.electionTicker.Reset(randomElectionTimeout())
		}
	}
}

// checkMasterOnline 检查主节点是否真的在线
func (c *Cluster) checkMasterOnline(masterNode *Node) bool {
	// 尝试向主节点发送请求，检查是否在线
	url := fmt.Sprintf("http://localhost%s/ping", masterNode.Addr)
	resp, err := http.Get(url)
	if err != nil {
		return false
	}
	defer resp.Body.Close()
	return resp.StatusCode == http.StatusOK
}

// startElection 发起Raft选举
func (c *Cluster) startElection() {
	// 检查是否已经有其他在线节点成为主节点
	// 遍历所有节点，检查是否有在线的节点已经是主节点
	var existingMaster *Node
	c.mu.Lock()
	for _, node := range c.Nodes {
		if node.Type == Master && node.Status == Online {
			existingMaster = node
			break
		}
	}
	// 如果已经有其他在线节点成为主节点，放弃选举
	if existingMaster != nil && existingMaster.ID != c.LocalNode.ID {
		log.Printf("节点 %s 发现已经有主节点 %s（ID：%s），放弃选举", c.LocalNode.Addr, existingMaster.Addr, existingMaster.ID)
		// 更新本地节点的 MasterID 为新主节点的 ID
		c.LocalNode.MasterID = existingMaster.ID
		log.Printf("节点 %s 更新 MasterID 为 %s", c.LocalNode.Addr, existingMaster.ID)
		c.mu.Unlock()
		return
	}

	// 直接标注 :6382 节点为主节点
	var targetMaster *Node
	for _, node := range c.Nodes {
		if node.Addr == ":6382" {
			targetMaster = node
			break
		}
	}
	// 如果找到 :6382 节点，标注它为主节点
	if targetMaster != nil {
		log.Printf("节点 %s 标注 :6382 节点为主节点", c.LocalNode.Addr)
		// 更新 :6382 节点的类型为 Master，状态为 Online
		targetMaster.Type = Master
		targetMaster.Status = Online
		// 清空 :6382 节点的 MasterID（因为它现在是主节点）
		targetMaster.MasterID = ""
		// 更新所有其他节点的类型为 Slave，并更新 MasterID 为 :6382 节点的 ID
		for _, node := range c.Nodes {
			if node.ID != targetMaster.ID {
				node.Type = Slave // 确保其他节点都是从节点
				node.MasterID = targetMaster.ID
				log.Printf("节点 %s 类型更新为 Slave，MasterID 更新为 %s", node.Addr, targetMaster.ID)
			}
		}
		// 更新本地节点的状态
		if c.LocalNode.ID == targetMaster.ID {
			// 如果本地节点就是 :6382，确保它保持为主节点状态
			c.LocalNode.Type = Master
			c.LocalNode.MasterID = ""
			log.Printf("节点 %s 成为主节点，停止选举循环", c.LocalNode.Addr)
			// 停止选举循环，因为本地节点已经是主节点
			c.electionTicker.Stop()
		} else {
			// 如果本地节点不是 :6382，确保它是从节点并更新 MasterID
			c.LocalNode.Type = Slave
			c.LocalNode.MasterID = targetMaster.ID
			log.Printf("从节点 %s 更新 MasterID 为 %s", c.LocalNode.Addr, targetMaster.ID)
		}
		// 立即广播集群状态，通知其他节点 :6382 已成为主节点
		c.mu.Unlock()
		c.broadcastClusterState()
		return
	}
	c.mu.Unlock()

	// 当有两个从节点时，使用端口号作为优先级：只有端口号较小的节点能发起选举
	// 提取本地节点的端口号
	localPort := c.LocalNode.Addr[1:] // 去掉冒号，得到端口号字符串
	// 找出所有其他从节点
	var otherSlave *Node
	for _, node := range c.Nodes {
		if node.ID != c.LocalNode.ID && node.Type == Slave {
			otherSlave = node
			break
		}
	}
	// 如果存在其他从节点，比较两个节点的端口号大小，只有端口号较小的节点能发起选举
	if otherSlave != nil {
		otherPort := otherSlave.Addr[1:] // 去掉冒号，得到端口号字符串
		if localPort > otherPort {
			log.Printf("节点 %s 发现其他从节点端口号较小，放弃选举", c.LocalNode.Addr)
			// 检查是否存在新主节点
			existingMaster = nil
			for _, node := range c.Nodes {
				if node.Type == Master && node.Status == Online && node.ID != c.LocalNode.ID {
					existingMaster = node
					break
				}
			}
			// 如果存在新主节点，更新本地节点的 MasterID
			if existingMaster != nil {
				c.LocalNode.MasterID = existingMaster.ID
				log.Printf("节点 %s 发现新主节点 %s（ID：%s），更新 MasterID", c.LocalNode.Addr, existingMaster.Addr, existingMaster.ID)
			}
			c.mu.Unlock()
			return
		}
		// 如果自己的端口号较小，等待一段时间，让其他从节点有机会放弃选举
		time.Sleep(time.Millisecond * 10)
		// 再次检查是否已经有其他在线节点成为主节点
		existingMaster = nil
		for _, node := range c.Nodes {
			if node.Type == Master && node.Status == Online {
				existingMaster = node
				break
			}
		}
		// 如果已经有其他在线节点成为主节点，放弃选举
		if existingMaster != nil && existingMaster.ID != c.LocalNode.ID {
			log.Printf("节点 %s 发现已经有主节点 %s（ID：%s），放弃选举", c.LocalNode.Addr, existingMaster.Addr, existingMaster.ID)
			// 更新本地节点的 MasterID 为新主节点的 ID
			c.LocalNode.MasterID = existingMaster.ID
			log.Printf("节点 %s 更新 MasterID 为 %s", c.LocalNode.Addr, existingMaster.ID)
			c.mu.Unlock()
			return
		}
	}
	// 即使没有在节点列表中发现其他从节点，也使用端口号作为优先级
	// 这是为了防止两个从节点同时发起选举时，它们的节点列表还没有同步
	// 直接使用端口号字符串进行比较，因为端口号都是数字字符串，字典序比较等同于数值比较
	if c.LocalNode.Addr > ":6382" {
		log.Printf("节点 %s 端口号较大，放弃选举", c.LocalNode.Addr)
		// 检查是否存在新主节点
		existingMaster = nil
		for _, node := range c.Nodes {
			if node.Type == Master && node.Status == Online && node.ID != c.LocalNode.ID {
				existingMaster = node
				break
			}
		}
		// 如果存在新主节点，更新本地节点的 MasterID
		if existingMaster != nil {
			c.LocalNode.MasterID = existingMaster.ID
			log.Printf("节点 %s 发现新主节点 %s（ID：%s），更新 MasterID", c.LocalNode.Addr, existingMaster.Addr, existingMaster.ID)
		}
		c.mu.Unlock()
		return
	}
	c.mu.Unlock()

	// 再次检查是否已经有其他在线节点成为主节点（防止在选举过程中有其他节点成为主节点）
	c.mu.Lock()
	existingMaster = nil
	for _, node := range c.Nodes {
		if node.Type == Master && node.Status == Online {
			existingMaster = node
			break
		}
	}
	// 如果已经有其他在线节点成为主节点，放弃选举
	if existingMaster != nil && existingMaster.ID != c.LocalNode.ID {
		log.Printf("节点 %s 发现已经有主节点 %s（ID：%s），放弃选举", c.LocalNode.Addr, existingMaster.Addr, existingMaster.ID)
		// 更新本地节点的 MasterID 为新主节点的 ID
		c.LocalNode.MasterID = existingMaster.ID
		log.Printf("节点 %s 更新 MasterID 为 %s", c.LocalNode.Addr, existingMaster.ID)
		c.mu.Unlock()
		return
	}
	c.mu.Unlock()

	// 向其他节点发送请求，获取它们的状态，然后再决定是否发起选举
	c.mu.RLock()
	onlineNodes := make([]*Node, 0)
	for _, node := range c.Nodes {
		if node.ID != c.LocalNode.ID && node.Status == Online {
			onlineNodes = append(onlineNodes, node)
		}
	}
	c.mu.RUnlock()

	for _, node := range onlineNodes {
		// 向目标节点发送请求，获取它的状态
		resp, err := http.Get(fmt.Sprintf("http://localhost%s/clusterState", node.Addr))
		if err != nil {
			log.Printf("向节点 %s 获取集群状态失败：%v", node.Addr, err)
			continue
		}
		defer resp.Body.Close()

		// 解析响应
		var clusterState ClusterState
		err = json.NewDecoder(resp.Body).Decode(&clusterState)
		if err != nil {
			log.Printf("解析节点 %s 的集群状态失败：%v", node.Addr, err)
			continue
		}

		// 检查目标节点是否已经成为了主节点
		for _, n := range clusterState.Nodes {
			if n.ID == node.ID && n.Type == Master {
				log.Printf("节点 %s 发现节点 %s 已经成为了主节点，放弃选举", c.LocalNode.Addr, node.Addr)
				return
			}
		}
	}

	// 自增任期
	c.mu.Lock()
	c.currentTerm++
	currentTerm := c.currentTerm
	selfID := c.LocalNode.ID
	// 给自己投票
	c.votedFor = selfID
	voteCount := 1
	c.mu.Unlock()

	log.Printf("节点 %s 发起选举，任期 %d，已获得自身投票", selfID, currentTerm)

	// 收集所有在线节点（排除自己）
	c.mu.RLock()
	onlineNodes = make([]*Node, 0)
	for _, node := range c.Nodes {
		if node.ID != selfID && node.Status == Online {
			onlineNodes = append(onlineNodes, node)
		}
	}
	c.mu.RUnlock()

	// 向其他节点请求投票
	var wg sync.WaitGroup
	voteChan := make(chan bool, len(onlineNodes))

	for _, node := range onlineNodes {
		wg.Add(1)
		go func(targetNode *Node) {
			defer wg.Done()
			voteGranted, err := c.requestVote(targetNode, currentTerm, selfID)
			if err != nil {
				log.Printf("向节点 %s 请求投票失败：%v", targetNode.Addr, err)
				voteChan <- false
				return
			}
			voteChan <- voteGranted
		}(node)
	}

	// 等待投票结果
	go func() {
		wg.Wait()
		close(voteChan)
	}()

	// 统计投票
	for granted := range voteChan {
		if granted {
			c.mu.Lock()
			voteCount++
			c.mu.Unlock()
		}
	}

	// 判断是否获得多数票
	c.mu.Lock()
	defer c.mu.Unlock()
	// 计算在线节点数
	onlineNodesCount := 0
	for _, node := range c.Nodes {
		if node.Status == Online {
			onlineNodesCount++
		}
	}
	// 计算多数票
	majority := (onlineNodesCount / 2) + 1
	if voteCount >= majority {
		// 选举成功，转换为主节点
		c.LocalNode.Type = Master
		oldMasterID := c.LocalNode.MasterID
		c.LocalNode.MasterID = ""
		// 继承原主节点的槽位
		var oldMasterNode *Node
		if node, ok := c.Nodes[oldMasterID]; ok {
			oldMasterNode = node
		} else {
			// 如果通过 ID 找不到，尝试通过地址查找原主节点
			for _, node := range c.Nodes {
				if node.Addr == oldMasterID {
					oldMasterNode = node
					break
				}
			}
		}
		if oldMasterNode != nil {
			c.LocalNode.Slots = oldMasterNode.Slots
			// 更新槽位映射
			for _, slot := range c.LocalNode.Slots {
				c.slotMap[slot] = c.LocalNode.ID
			}
		}
		log.Printf("节点 %s 选举成功，任期 %d，成为新主节点（获得 %d/%d 票，ID：%s）",
			c.LocalNode.Addr, currentTerm, voteCount, onlineNodesCount, c.LocalNode.ID)
		// 立即广播集群状态，通知其他节点自己已经成为了主节点
		c.broadcastClusterState()
		// 启动数据落盘（主节点专属）
		go c.persistDataLoop()
		// 通知其他从节点更新主节点信息
		log.Printf("节点 %s 成为新主节点，通知其他从节点更新主节点信息", c.LocalNode.Addr)
	} else {
		log.Printf("节点 %s 选举失败，任期 %d，仅获得 %d/%d 票",
			c.LocalNode.Addr, currentTerm, voteCount, onlineNodesCount)
	}
}

// requestVote 向目标节点请求投票
func (c *Cluster) requestVote(targetNode *Node, term int, candidateID string) (bool, error) {
	// 检查目标节点是否在线
	if targetNode.Status != Online {
		return false, fmt.Errorf("目标节点离线")
	}
	// 尝试向目标节点发送请求
	url := fmt.Sprintf("http://localhost%s/requestVote?term=%d&candidateID=%s&candidateAddr=%s",
		targetNode.Addr, term, candidateID, c.LocalNode.Addr)
	resp, err := http.Get(url)
	if err != nil {
		return false, err
	}
	defer resp.Body.Close()

	var voteResp map[string]interface{}
	if err := json.NewDecoder(resp.Body).Decode(&voteResp); err != nil {
		return false, err
	}

	return voteResp["voteGranted"].(bool), nil
}

// registerRaftHandlers 注册Raft相关HTTP接口
func (c *Cluster) registerRaftHandlers() {
	// 处理投票请求
	c.serveMux.HandleFunc("/requestVote", func(w http.ResponseWriter, r *http.Request) {
		termStr := r.URL.Query().Get("term")
		candidateID := r.URL.Query().Get("candidateID")
		candidateAddr := r.URL.Query().Get("candidateAddr")

		term, err := strconv.Atoi(termStr)
		if err != nil || term < 0 {
			http.Error(w, "无效的任期", http.StatusBadRequest)
			return
		}

		c.mu.Lock()
		defer c.mu.Unlock()

		// 响应结果
		voteGranted := false
		// 任期更新：如果请求任期大于当前任期，更新并重置投票状态
		if term > c.currentTerm {
			c.currentTerm = term
			c.votedFor = ""
		}

		// 满足投票条件：任期一致 + 未投票 + 候选人数据较新（简化：默认认为有效）
		if term == c.currentTerm && c.votedFor == "" {
			// 当有两个从节点时，使用节点 ID 的优先级机制：只有 ID 较小的节点能够获得投票
			if candidateID < c.LocalNode.ID {
				// 候选人的 ID 小于自己的 ID，给它投票
				c.votedFor = candidateID
				voteGranted = true
				log.Printf("节点 %s 给候选人 %s（地址：%s）投票（任期 %d，候选人 ID 小于自己的 ID）", c.LocalNode.Addr, candidateID, candidateAddr, term)
			} else {
				// 候选人的 ID 大于或等于自己的 ID，拒绝投票
				log.Printf("节点 %s 拒绝给候选人 %s（地址：%s）投票（任期 %d，候选人 ID 大于或等于自己的 ID）", c.LocalNode.Addr, candidateID, candidateAddr, term)
			}
		} else {
			log.Printf("节点 %s 拒绝给候选人 %s 投票（任期 %d，当前任期 %d，已投票给 %s）",
				c.LocalNode.Addr, candidateID, term, c.currentTerm, c.votedFor)
		}

		json.NewEncoder(w).Encode(map[string]interface{}{
			"term":        c.currentTerm,
			"voteGranted": voteGranted,
		})
	})
}
